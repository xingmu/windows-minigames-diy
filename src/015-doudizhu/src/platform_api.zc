// ==================== 数学辅助 ====================

fn abs(x: i32) -> i32 {
    return if x < 0 { -x } else { x };
}

fn min(a: i32, b: i32) -> i32 {
    return if a < b { a } else { b };
}

fn max(a: i32, b: i32) -> i32 {
    return if a > b { a } else { b };
}

fn sqrt(n: i32) -> i32 {
    if n < 0 { return 0; }
    var x = n;
    var y = 1;
    while y < x {
        x = (x + y) / 2;
        y = n / x;
    }
    return x;
}

// ==================== 随机数 ====================

static mut rng_seed: u32 = 1;

fn setRandomSeed(seed: u32) {
    rng_seed = seed;
}

fn randInt(min_val: i32, max_val: i32) -> i32 {
    rng_seed = rng_seed * 1103515245 + 12345;
    var r = (rng_seed >> 16) % ((max_val - min_val + 1) as u32);
    return min_val + r as i32;
}
