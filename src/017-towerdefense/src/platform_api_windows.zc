}

pub fn initPlatform() {
    // 初始化
}

pub fn shutdownPlatform() {
    if windowDC != nil {
        DeleteDC(windowDC);
        windowDC = nil;
    }
    if backBuffer != nil {
        DeleteDC(backBuffer);
        backBuffer = nil;
    }
}
