    // 第1洞: 简单直洞
    return Course.{
        holes: [
            Hole.{ x: 700, y: 300, par: 3 },
            Hole.{ x: 650, y: 150, par: 3 },
            Hole.{ x: 200, y: 500, par: 4 },
            Hole.{ x: 400, y: 300, par: 3 },
            Hole.{ x: 700, y: 500, par: 3 },
            Hole.{ x: 150, y: 150, par: 4 },
            Hole.{ x: 400, y: 100, par: 3 },
            Hole.{ x: 600, y: 450, par: 4 },
            Hole.{ x: 350, y: 400, par: 3 },
        ],
        teeX: 100,
        teeY: 300,
        holeX: 700,
        holeY: 300,
        obstacles: [
            Obstacle.{ x1: 0, y1: 0, x2: 0, y2: 0, typ: 0 },
