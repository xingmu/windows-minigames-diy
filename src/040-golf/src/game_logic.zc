// game_logic.zc - Zen-C 高尔夫游戏核心逻辑
// 鼠标蓄力方向，挥杆击球

// ==================== 游戏常量 ====================

const GAME_WIDTH: i32 = 800;
const GAME_HEIGHT: i32 = 600;

// 球半径
const BALL_RADIUS: i32 = 8;

// 洞的半径
const HOLE_RADIUS: i32 = 14;

// 最大击球力度
const MAX_POWER: i32 = 30;

// 摩擦系数 (每帧速度衰减)
const FRICTION: i32 = 3;

// 最小速度阈值
const MIN_VELOCITY: i32 = 1;

// 墙壁反弹系数
const BOUNCE: i32 = 80;

// ==================== 游戏状态 ====================

enum GameStatus {
    Ready,       // 等待击球
    Aiming,      // 瞄准中
    Dragging,    // 拖拽蓄力
    Moving,      // 球运动中
    HoleIn,     // 进球!
    GameComplete,// 洞完成
}

struct Obstacle {
    x1: i32, y1: i32, x2: i32, y2: i32,  // 矩形区域
    typ: i32,  // 0=墙, 1=水, 2=沙坑
}

struct Hole {
    x: i32, y: i32, par: i32,
}

struct Course {
    holes: [9]Hole,
    obstacles: [20]Obstacle,
    obsCount: i32,
    teeX: i32, teeY: i32,
    holeX: i32, holeY: i32,
    name: string,
}

struct GolfState {
    ballX: i32,
    ballY: i32,
    vx: i32,
    vy: i32,
    radius: i32,
    
    status: GameStatus,
    currentHole: i32,
    strokes: i32,
    totalStrokes: i32,
    score: i32,  // 相对于标准杆
    
    mouseX: i32,
    mouseY: i32,
    dragStartX: i32,
    dragStartY: i32,
    aimX: i32,
    aimY: i32,
    power: i32,
    
    width: i32,
    height: i32,
    
    course: Course,
    
    // 进球动画
    holeAnimTimer: i32,
}

// ==================== 课程数据 ====================

