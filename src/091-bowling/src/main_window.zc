fn intToString(n: i32) -> str {
    // 简化实现
    if n == 0 {
        return "0";
    }
    
    var negative = n < 0;
    var x = if negative { -n } else { n };
    var result = "";
    
    while x > 0 {
        var digit = x % 10;
        result = chr(digit + 48) ++ result;
        x = x / 10;
    }
    
    return if negative { "-" ++ result } else { result };
}

fn chr(n: i32) -> str {
    // 返回单个字符
    return str(n);
}
