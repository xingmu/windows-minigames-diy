import "io.zc";
// platform_api.zc - Zen-C 足球游戏平台API封装
// 所有平台使用同一份Zen-C代码，通过条件编译处理平台差异

// import "ffi.zc";

// ==================== 平台检测宏 ====================

#if defined(_WIN32) || defined(WIN32) || defined(__WIN32__) || defined(__NT__)
    #define IS_WINDOWS 1
    #define IS_LINUX 0
    #define IS_MACOS 0
#elif defined(__linux__)
    #define IS_WINDOWS 0
    #define IS_LINUX 1
    #define IS_MACOS 0
#elif defined(__APPLE__) && defined(__MACH__)
    #define IS_WINDOWS 0
    #define IS_LINUX 0
    #define IS_MACOS 1
#else
    #define IS_WINDOWS 1
    #define IS_LINUX 0
    #define IS_MACOS 0
#endif

// ==================== 通用类型定义 ====================

// 窗口句柄类型
type WindowHandle = *void;

// 图形上下文类型
type GraphicsContext = *void;

// 事件类型枚举
enum EventType {
    EventNone,
    EventKeyDown,
    EventKeyUp,
    EventMouseMove,
    EventMouseDown,
    EventMouseUp,
    EventWindowClose,
    EventWindowResize,
    EventTimer
}

// 按键代码枚举
enum KeyCode {
    KeyUnknown,
    KeyUp,
    KeyDown,
    KeyLeft,
    KeyRight,
    KeySpace,
    KeyEscape,
    KeyR,
    KeyW,
    KeyA,
    KeyS,
    KeyD,
    KeyP
}

// 事件结构
struct Event {
    type: EventType,
    key: KeyCode,
    x: i32,
    y: i32,
    width: i32,
    height: i32
}

// ==================== 平台特定API封装 ====================

#if IS_WINDOWS

// Windows API封装
extern "user32.dll" fn CreateWindowExA(
    dwExStyle: u32,
    lpClassName: *def i8,
    lpWindowName: *def i8,
    dwStyle: u32,
    x: i32,
    y: i32,
    nWidth: i32,
    nHeight: i32,
    hWndParent: WindowHandle,
    hMenu: *void,
    hInstance: *void,
    lpParam: *void
) -> WindowHandle;

extern "user32.dll" fn ShowWindow(hWnd: WindowHandle, nCmdShow: i32) -> bool;
extern "user32.dll" fn UpdateWindow(hWnd: WindowHandle) -> bool;
extern "user32.dll" fn GetMessageA(lpMsg: *void, hWnd: WindowHandle, wMsgFilterMin: u32, wMsgFilterMax: u32) -> bool;
extern "user32.dll" fn TranslateMessage(lpMsg: *void) -> bool;
extern "user32.dll" fn DispatchMessageA(lpMsg: *void) -> i32;
extern "user32.dll" fn InvalidateRect(hWnd: WindowHandle, lpRect: *void, bErase: bool) -> bool;
extern "user32.dll" fn BeginPaint(hWnd: WindowHandle, lpPaint: *void) -> GraphicsContext;
extern "user32.dll" fn EndPaint(hWnd: WindowHandle, lpPaint: *void);
extern "user32.dll" fn GetClientRect(hWnd: WindowHandle, lpRect: *void) -> bool;
extern "user32.dll" fn FillRect(hDC: GraphicsContext, lprc: *void, hbr: *void) -> i32;
extern "user32.dll" fn Rectangle(hDC: GraphicsContext, left: i32, top: i32, right: i32, bottom: i32) -> bool;
extern "user32.dll" fn Ellipse(hDC: GraphicsContext, left: i32, top: i32, right: i32, bottom: i32) -> bool;
extern "user32.dll" fn CreateSolidBrush(color: u32) -> *void;
extern "user32.dll" fn SelectObject(hDC: GraphicsContext, hObject: *void) -> *void;
extern "user32.dll" fn DeleteObject(hObject: *void) -> bool;
extern "user32.dll" fn SetTimer(hWnd: WindowHandle, nIDEvent: u32, uElapse: u32, lpTimerFunc: *void) -> u32;
extern "user32.dll" fn KillTimer(hWnd: WindowHandle, uIDEvent: u32) -> bool;
extern "user32.dll" fn PostQuitMessage(nExitCode: i32);
extern "kernel32.dll" fn GetModuleHandleA(lpModuleName: *def i8) -> *void;
extern "user32.dll" fn SetCapture(hWnd: WindowHandle) -> WindowHandle;
extern "user32.dll" fn ReleaseCapture();

// Windows常量
def WS_OVERLAPPEDWINDOW: u32 = 0x00CF0000;
def CW_USEDEFAULT: i32 = 0x80000000;
def WM_CREATE: u32 = 0x0001;
def WM_PAINT: u32 = 0x000F;
def WM_KEYDOWN: u32 = 0x0100;
def WM_KEYUP: u32 = 0x0101;
def WM_MOUSEMOVE: u32 = 0x0200;
def WM_LBUTTONDOWN: u32 = 0x0201;
def WM_LBUTTONUP: u32 = 0x0202;
def WM_TIMER: u32 = 0x0113;
def WM_DESTROY: u32 = 0x0002;
def COLOR_WINDOW: i32 = 5;
def IDC_ARROW: *def i8 = 32512;
def MK_LBUTTON: u32 = 0x0001;

#elif IS_LINUX

// Linux GTK API封装（简化版本）
extern "libgtk-3.so" fn gtk_init(argc: *i32, argv: **i8);
extern "libgtk-3.so" fn gtk_window_new(type: i32) -> WindowHandle;
extern "libgtk-3.so" fn gtk_window_set_title(window: WindowHandle, title: *def i8);
extern "libgtk-3.so" fn gtk_window_set_default_size(window: WindowHandle, width: i32, height: i32);
extern "libgtk-3.so" fn gtk_widget_show_all(widget: WindowHandle);
extern "libgtk-3.so" fn gtk_main();
extern "libgtk-3.so" fn gtk_main_quit();

def GTK_WINDOW_TOPLEVEL: i32 = 0;

#elif IS_MACOS

// macOS Cocoa API封装（简化版本）
extern fn objc_getClass(class_name: *def i8) -> *void;
extern fn sel_registerName(selector: *def i8) -> *void;
extern fn objc_msgSend(receiver: *void, selector: *void, ...) -> *void;

#endif

// ==================== 跨平台API抽象 ====================

// 创建窗口
fn create_window(title: string, width: i32, height: i32) -> WindowHandle {
    #if IS_WINDOWS
        let hInstance = GetModuleHandleA(null);
        let hwnd = CreateWindowExA(
            0,
            "STATIC",
            title.c_str(),
            WS_OVERLAPPEDWINDOW,
            CW_USEDEFAULT, CW_USEDEFAULT,
            width, height,
            null,
            null,
            hInstance,
            null
        );
        return hwnd;
    #elif IS_LINUX
        let argc = 0;
        let argv: **i8 = null;
        gtk_init(&argc, &argv);
        
        let window = gtk_window_new(GTK_WINDOW_TOPLEVEL);
        gtk_window_set_title(window, title.c_str());
        gtk_window_set_default_size(window, width, height);
        return window;
    #elif IS_MACOS
        return nil;
    #endif
}

// 显示窗口
fn show_window(window: WindowHandle) {
    #if IS_WINDOWS
        ShowWindow(window, 1);
        UpdateWindow(window);
    #elif IS_LINUX
        gtk_widget_show_all(window);
    #elif IS_MACOS
    #endif
}

// 运行主事件循环
fn run_event_loop(window: WindowHandle) {
    #if IS_WINDOWS
        let msg: [u8; 64] = [0; 64];
        while GetMessageA(&msg, null, 0, 0) {
            TranslateMessage(&msg);
            DispatchMessageA(&msg);
        }
    #elif IS_LINUX
        gtk_main();
    #elif IS_MACOS
    #endif
}

// 退出应用程序
fn quit_application() {
    #if IS_WINDOWS
        PostQuitMessage(0);
    #elif IS_LINUX
        gtk_main_quit();
    #elif IS_MACOS
    #endif
}

// 设置游戏定时器
fn set_game_timer(window: WindowHandle, interval_ms: u32) {
    #if IS_WINDOWS
        SetTimer(window, 1, interval_ms, null);
    #elif IS_LINUX || IS_MACOS
    #endif
}

// 停止游戏定时器
fn stop_game_timer(window: WindowHandle) {
    #if IS_WINDOWS
        KillTimer(window, 1);
    #elif IS_LINUX || IS_MACOS
    #endif
}

// 强制重绘窗口
fn redraw_window(window: WindowHandle) {
    #if IS_WINDOWS
        InvalidateRect(window, null, 1);
    #elif IS_LINUX || IS_MACOS
    #endif
}

// 获取窗口客户端区域
fn get_window_size(window: WindowHandle, width: &i32, height: &i32) -> bool {
    #if IS_WINDOWS
        let rect: [i32; 4] = [0; 4];
        if GetClientRect(window, &rect) {
            *width = rect[2] - rect[0];
            *height = rect[3] - rect[1];
            return true;
        }
        return false;
    #elif IS_LINUX || IS_MACOS
        return true;
    #endif
}

// ==================== 图形API ====================

// 颜色结构
struct Color {
    r: u8,
    g: u8,
    b: u8,
    a: u8,
}

impl Color {
    pub static fn rgb(r: u8, g: u8, b: u8) -> Color {
        return Color { r: r, g: g, b: b, a: 255 };
    }
    
    pub static fn rgba(r: u8, g: u8, b: u8, a: u8) -> Color {
        return Color { r: r, g: g, b: b, a: a };
    }
    
    pub fn to_u32(self) -> u32 {
        return ((u32)(self.a)) << 24 | ((u32)(self.r)) << 16 | ((u32)(self.g)) << 8 | ((u32)(self.b));
    }
}

// 创建颜色
fn rgb(r: u8, g: u8, b: u8) -> Color {
    Color.rgb(r, g, b)
}

fn rgba(r: u8, g: u8, b: u8, a: u8) -> Color {
    Color.rgba(r, g, b, a)
}

// 绘制矩形
fn draw_rect(ctx: GraphicsContext, x: i32, y: i32, width: i32, height: i32, color: Color) {
    #if IS_WINDOWS
        let c = (color.(u32)r) | ((color.(u32)g) << 8) | ((color.(u32)b) << 16);
        let brush = CreateSolidBrush(c);
        let old_brush = SelectObject(ctx, brush);
        
        let rect: [i32; 4] = [x, y, x + width, y + height];
        FillRect(ctx, &rect, brush);
        
        SelectObject(ctx, old_brush);
        DeleteObject(brush);
    #elif IS_LINUX || IS_MACOS
    #endif
}

// 绘制圆形填充
fn fill_circle(ctx: GraphicsContext, cx: i32, cy: i32, radius: i32, color: Color) {
    #if IS_WINDOWS
        let c = (color.(u32)r) | ((color.(u32)g) << 8) | ((color.(u32)b) << 16);
        let brush = CreateSolidBrush(c);
        let old_brush = SelectObject(ctx, brush);
        
        Ellipse(ctx, cx - radius, cy - radius, cx + radius, cy + radius);
        
        SelectObject(ctx, old_brush);
        DeleteObject(brush);
    #elif IS_LINUX || IS_MACOS
    #endif
}

// 绘制线条
fn draw_line(ctx: GraphicsContext, x1: i32, y1: i32, x2: i32, y2: i32, color: Color, width: i32) {
    #if IS_WINDOWS
        let c = (color.(u32)r) | ((color.(u32)g) << 8) | ((color.(u32)b) << 16);
        let pen = CreatePen(0, width, c);
        let old_pen = SelectObject(ctx, pen);
        
        MoveToEx(ctx, x1, y1, null);
        LineTo(ctx, x2, y2);
        
        SelectObject(ctx, old_pen);
        DeleteObject(pen);
    #elif IS_LINUX || IS_MACOS
    #endif
}

#if IS_WINDOWS
extern "gdi32.dll" fn MoveToEx(hdc: GraphicsContext, x: i32, y: i32, lpPoint: rawptr) -> i32;
extern "gdi32.dll" fn LineTo(hdc: GraphicsContext, x: i32, y: i32) -> i32;
extern "gdi32.dll" fn CreatePen(style: i32, width: i32, color: u32) -> rawptr;
#endif

