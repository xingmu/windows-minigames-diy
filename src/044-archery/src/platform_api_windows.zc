// Framebuffer data for direct pixel access
private var mut fbWidth: int = 800;
private var mut fbHeight: int = 600;
private var mut fbBuffer: [800 * 600]u32;
private var mut fbValid: bool = false;

pub fn fb_init(handle: WindowHandle, width: int, height: int) -> bool {
    fbWidth = width;
    fbHeight = height;
    fbValid = true;
    return true;
}

pub fn fb_shutdown() {
    fbValid = false;
}

pub fn fb_clear(color: Color) {
    if !fbValid {
        return;
    }
    for i in 0..(fbWidth * fbHeight) {
        fbBuffer[i] = color;
    }
}

pub fn fb_draw_rect(x: int, y: int, w: int, h: int, color: Color) {
    if !fbValid return;
    if x < 0 { w = w + x; x = 0; }
    if y < 0 { h = h + y; y = 0; }
    if x + w > fbWidth { w = fbWidth - x; }
    if y + h > fbHeight { h = fbHeight - y; }
    if w <= 0 || h <= 0 return;
    
    for py in y..(y + h) {
        for px in x..(x + w) {
            var idx = py * fbWidth + px;
            if idx >= 0 && idx < fbWidth * fbHeight {
                fbBuffer[idx] = color;
            }
        }
    }
}

pub fn fb_draw_pixel(x: int, y: int, color: Color) {
    if !fbValid return;
    if x < 0 || x >= fbWidth || y < 0 || y >= fbHeight return;
    fbBuffer[y * fbWidth + x] = color;
}

pub fn fb_draw_line(x1: int, y1: int, x2: int, y2: int, color: Color) {
    if !fbValid return;
    
    var dx = x2 - x1;
    var dy = y2 - y1;
    var steps = if abs(dx) > abs(dy) { abs(dx) } else { abs(dy) };
    
    if steps == 0 {
        fb_draw_pixel(x1, y1, color);
        return;
    }
    
    var fx = dx as float / steps as float;
    var fy = dy as float / steps as float;
    
    var cx = x1 as float;
    var cy = y1 as float;
    
    for i in 0..steps {
        fb_draw_pixel(cx as int, cy as int, color);
        cx = cx + fx;
        cy = cy + fy;
    }
}

pub fn fb_draw_circle(cx: int, cy: int, radius: int, color: Color) {
    if !fbValid return;
    var d = 3 - 2 * radius;
    var x = 0;
    var y = radius;
    
    loop {
        fb_draw_pixel(cx + x, cy + y, color);
        fb_draw_pixel(cx - x, cy + y, color);
        fb_draw_pixel(cx + x, cy - y, color);
        fb_draw_pixel(cx - x, cy - y, color);
        fb_draw_pixel(cx + y, cy + x, color);
        fb_draw_pixel(cx - y, cy + x, color);
        fb_draw_pixel(cx + y, cy - x, color);
        fb_draw_pixel(cx - y, cy - x, color);
        
        if d < 0 {
            d = d + 4 * x + 6;
        } else {
            d = d + 4 * (x - y) + 10;
            y = y - 1;
        }
        
        x = x + 1;
        if x > y {
            break;
        }
    }
}

pub fn fb_fill_circle(cx: int, cy: int, radius: int, color: Color) {
    if !fbValid return;
    for y in (-radius)..(radius + 1) {
        for x in (-radius)..(radius + 1) {
            if x * x + y * y <= radius * radius {
                fb_draw_pixel(cx + x, cy + y, color);
            }
        }
    }
}

private fn abs(x: int) -> int {
    return if x < 0 { -x } else { x };
}

private fn float absF(x: float) -> float {
    return if x < 0.0 { -x } else { x };
}

pub fn fb_draw_text_size(x: int, y: int, text: str, color: Color, size: int) {
    // Simplified text - draw as colored rectangles for now
    var px = x;
    for i in 0..len(text) {
        var c = text[i];
        if c == 0 break;
        // Skip null chars
        if c > 0 {
            // Draw char as a small rect placeholder
            fb_draw_rect(px, y, size / 2, size, color);
            px = px + size / 2 + 1;
        }
    }
}

