    pt: rawptr,
}

private struct WinData {
    hwnd: rawptr,
    dc: rawptr,
    memDC: rawptr,
    bitmap: rawptr,
    buffer: rawptr,
    width: int,
    height: int,
    running: bool,
    mouseX: int,
    mouseY: int,
    mouseDown: bool,
    mouseUp: bool,
    mouseButton: MouseButton,
    keyDown: bool,
    keyUp: bool,
    lastKey: VirtualKey,
}

private var mut winData: WinData;

fn windowProc(hwnd: rawptr, msg: u32, wParam: rawptr, lParam: rawptr) -> rawptr {
    match msg {
        WM_DESTROY => { 
            winData.running = false;
            return nil; 
        }
        WM_PAINT => { 
            return nil; 
        }
        WM_MOUSEMOVE => {
            winData.mouseX = (lParam as i32) & 0xFFFF;
            winData.mouseY = ((lParam as i32) >> 16) & 0xFFFF;
        }
        WM_LBUTTONDOWN => {
            winData.mouseDown = true;
            winData.mouseButton = MouseButton.Left;
        }
        WM_LBUTTONUP => {
            winData.mouseUp = true;
            winData.mouseButton = MouseButton.Left;
        }
        WM_RBUTTONDOWN => {
            winData.mouseDown = true;
            winData.mouseButton = MouseButton.Right;
        }
        WM_RBUTTONUP => {
            winData.mouseUp = true;
            winData.mouseButton = MouseButton.Right;
        }
        WM_KEYDOWN => {
            winData.keyDown = true;
            winData.lastKey = wParam as VirtualKey;
        }
        WM_KEYUP => {
            winData.keyUp = true;
            winData.lastKey = wParam as VirtualKey;
        }
        _ => {}
    }
    return nil;
}

fn createWindow(title: str, width: int, height: int) -> WindowHandle {
    winData.hwnd = nil;
    winData.width = width;
    winData.height = height;
    winData.running = false;
    winData.mouseX = width / 2;
    winData.mouseY = height / 2;
    winData.mouseDown = false;
    winData.mouseUp = false;
    winData.keyDown = false;
    winData.keyUp = false;
    return &winData as WindowHandle;
}

fn closeWindow(handle: WindowHandle) {
}

fn setWindowTitle(handle: WindowHandle, title: str) {
}

fn getWindowSize(handle: WindowHandle) -> (int, int) {
    return (winData.width, winData.height);
}

fn pollEvent(handle: WindowHandle, event: &Event) -> bool {
    event.msg = MessageType.None;
    event.mouse.x = winData.mouseX;
    event.mouse.y = winData.mouseY;
    
    if winData.mouseDown {
        winData.mouseDown = false;
        event.msg = MessageType.MouseDown;
        event.mouse.button = winData.mouseButton;
        return true;
    }
    
    if winData.mouseUp {
        winData.mouseUp = false;
        event.msg = MessageType.MouseUp;
        event.mouse.button = winData.mouseButton;
        return true;
    }
    
    if winData.keyDown {
        winData.keyDown = false;
        event.msg = MessageType.KeyDown;
        event.key.key = winData.lastKey;
        event.key.pressed = true;
        return true;
    }
    
    if winData.keyUp {
        winData.keyUp = false;
        event.msg = MessageType.KeyUp;
        event.key.key = winData.lastKey;
        event.key.pressed = false;
        return true;
    }
    
    return false;
}

fn waitEvent(handle: WindowHandle, event: &Event) {
    pollEvent(handle, event);
}

fn isKeyDown(key: VirtualKey) -> bool {
    return false;
}

