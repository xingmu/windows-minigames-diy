// 事件处理器类型
pub type KeyHandler = fn(key: KeyCode) -> bool;
pub type TimerHandler = fn() -> bool;
pub type PaintHandler = fn(w: int, h: int);
pub type MouseHandler = fn(x: int, y: int, button: MouseButton);
pub type DestroyHandler = fn();
pub type UpdateHandler = fn();

// 事件处理器变量
private let key_handler: KeyHandler = nil;
private let timer_handler: TimerHandler = nil;
private let paint_handler: PaintHandler = nil;
private let mouse_handler: MouseHandler = nil;
private let destroy_handler: DestroyHandler = nil;
private let update_handler: UpdateHandler = nil;

// 设置事件处理器
pub fn set_key_handler(handler: KeyHandler) {
    key_handler = handler;
}

pub fn set_timer_handler(handler: TimerHandler) {
    timer_handler = handler;
}

pub fn set_paint_handler(handler: PaintHandler) {
    paint_handler = handler;
}

pub fn set_mouse_handler(handler: MouseHandler) {
    mouse_handler = handler;
}

pub fn set_destroy_handler(handler: DestroyHandler) {
    destroy_handler = handler;
}

pub fn set_update_handler(handler: UpdateHandler) {
    update_handler = handler;
}

// 键盘码
enum KeyCode {
    None = 0,
    Escape = 0x1B,
    Space = 0x20,
    Enter = 0x0D,
    Tab = 0x09,
    Backspace = 0x08,
    Left = 0x25,
    Up = 0x26,
    Right = 0x27,
    Down = 0x28,
    Key0 = 0x30,
    Key1 = 0x31,
    Key2 = 0x32,
    Key3 = 0x33,
    Key4 = 0x34,
    Key5 = 0x35,
    Key6 = 0x36,
    Key7 = 0x37,
    Key8 = 0x38,
    Key9 = 0x39,
    A = 0x41,
    B = 0x42,
    C = 0x43,
    D = 0x44,
    E = 0x45,
    F = 0x46,
    G = 0x47,
    H = 0x48,
    I = 0x49,
    J = 0x4A,
    K = 0x4B,
    L = 0x4C,
    M = 0x4D,
    N = 0x4E,
    O = 0x4F,
    P = 0x50,
    Q = 0x51,
    R = 0x52,
    S = 0x53,
    T = 0x54,
    U = 0x55,
    V = 0x56,
    W = 0x57,
    X = 0x58,
    Y = 0x59,
    Z = 0x5A,
};

// 鼠标按钮
enum MouseButton {
    None = 0,
    Left = 1,
    Right = 2,
    Middle = 3,
};

// 图形上下文
pub type GraphicsContext = rawptr;

pub fn draw_rect(ctx: GraphicsContext, x: int, y: int, w: int, h: int, color: u32) {
    fb_draw_rect(x, y, w, h, color);
}

pub fn draw_circle(ctx: GraphicsContext, cx: int, cy: int, radius: int, color: u32) {
    fb_draw_circle(cx, cy, radius, color);
}

fn abs(x: int) -> int {
    return if x < 0 { -x } else { x };
}

fn rgb(r: u8, g: u8, b: u8) -> u32 {
    return (u32)0xFF000000 | (((u32)r) << 16) | (((u32)g) << 8) | ((u32)b);
}
