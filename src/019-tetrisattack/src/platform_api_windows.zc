// ============================================================================
// 简化 API 实现（供实际游戏使用）
// ============================================================================

// 帧缓冲数据
pub struct FrameBufferData {
    valid: bool,
    width: int,
    height: int,
    pitch: int,
    buffer: rawptr,
}

pub let fb_data = FrameBufferData { valid: false, width: 0, height: 0, pitch: 0, buffer: null };

pub fn fb_init(window: WindowHandle, width: int, height: int) {
    fb_data.valid = true;
    fb_data.width = width;
    fb_data.height = height;
    fb_data.pitch = width * 4;
}

pub fn fb_shutdown() {
    fb_data.valid = false;
}

pub fn fb_clear(color: u32) {
    if !fb_data.valid { return; }
    let pixels = fb_data.(u32)(buffer) mut;
    let count = (fb_data.pitch * fb_data.height) / 4;
    for i in 0..count {
        pixels[i] = color;
    }
}

pub fn fb_set_pixel(x: int, y: int, color: u32) {
    if !fb_data.valid { return; }
    if x < 0 || x >= fb_data.width || y < 0 || y >= fb_data.height { return; }
    let offset = y * (fb_data.pitch / 4) + x;
    let pixels = fb_data.(u32)(buffer) mut;
    pixels[offset] = color;
}

pub fn fb_get_pixel(x: int, y: int) -> u32 {
    if !fb_data.valid { return 0xFF000000; }
    if x < 0 || x >= fb_data.width || y < 0 || y >= fb_data.height { return 0xFF000000; }
    let offset = y * (fb_data.pitch / 4) + x;
    let pixels = (u32)(fb_data.buffer);
    return pixels[offset];
}

pub fn fb_draw_line(x1: int, y1: int, x2: int, y2: int, color: u32) {
    let dx = abs(x2 - x1);
    let dy = abs(y2 - y1);
    let sx = if x1 < x2 { 1 } else { -1 };
    let sy = if y1 < y2 { 1 } else { -1 };
    let err = dx - dy;
    
    loop {
        fb_set_pixel(x1, y1, color);
        if x1 == x2 && y1 == y2 { break; }
        let e2 = 2 * err;
        if e2 > -dy { err = err - dy; x1 = x1 + sx; }
        if e2 < dx { err = err + dx; y1 = y1 + sy; }
    }
}

pub fn fb_draw_rect(x: int, y: int, w: int, h: int, color: u32) {
    fb_draw_line(x, y, x + w, y, color);
    fb_draw_line(x + w, y, x + w, y + h, color);
    fb_draw_line(x + w, y + h, x, y + h, color);
    fb_draw_line(x, y + h, x, y, color);
}

pub fn fb_fill_rect(x: int, y: int, w: int, h: int, color: u32) {
    for py in y..(y + h) {
        for px in x..(x + w) {
            fb_set_pixel(px, py, color);
        }
    }
}

pub fn fb_draw_circle(cx: int, cy: int, radius: int, color: u32) {
    let d = 3 - 2 * radius;
    let x = 0;
    let y = radius;
    
    loop {
        fb_set_pixel(cx + x, cy + y, color);
        fb_set_pixel(cx - x, cy + y, color);
        fb_set_pixel(cx + x, cy - y, color);
        fb_set_pixel(cx - x, cy - y, color);
        fb_set_pixel(cx + y, cy + x, color);
        fb_set_pixel(cx - y, cy + x, color);
        fb_set_pixel(cx + y, cy - x, color);
        fb_set_pixel(cx - y, cy - x, color);
        
        if d < 0 {
            d = d + 4 * x + 6;
        } else {
            d = d + 4 * (x - y) + 10;
            y = y - 1;
        }
        x = x + 1;
        if x > y { break; }
    }
}

pub fn fb_draw_text_size(x: int, y: int, text: str, color: u32, size: int) {
    // 简化实现
    let px = x;
    let py = y;
    let charW = size * 8 / 10;
    let charH = size;
    
    for i in 0..len(text) {
        if text[i] == '\n' {
            py = py + charH;
            px = x;
            continue;
        }
        fb_fill_rect(px, py, charW, charH, color);
        px = px + charW;
        if px > fb_data.width - charW {
            py = py + charH;
            px = x;
        }
    }
}

