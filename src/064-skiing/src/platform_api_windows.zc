// 为了演示框架用法，提供一个最小化的 stub 实现
// 实际游戏开发需要提供完整的 Windows API 绑定

pub struct WNDCLASSEX {
    cbSize: u32,
    style: u32,
    lpfnWndProc: rawptr,
    cbClsExtra: i32,
    cbWndExtra: i32,
    hInstance: rawptr,
    hIcon: rawptr,
    hCursor: rawptr,
    hbrBackground: rawptr,
    lpszMenuName: rawptr,
    lpszClassName: rawptr,
    hIconSm: rawptr,
}

pub struct MSG {
    hwnd: rawptr,
    message: u32,
    wParam: rawptr,
    lParam: rawptr,
    time: u32,
    pt: rawptr,
}

// 窗口过程函数
// 这个函数由 Windows 调用处理消息
fn windowProc(hwnd: rawptr, msg: u32, wParam: rawptr, lParam: rawptr) -> rawptr {
    match msg {
        WM_DESTROY => {
            // 发送 WM_QUIT 消息
            return nil;
        }
        WM_PAINT => {
            // 重绘
            return nil;
        }
        _ => {
            // 调用默认窗口过程
            return nil;
        }
    }
}
