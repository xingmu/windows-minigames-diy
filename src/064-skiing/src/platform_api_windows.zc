fn getWindowSize(handle: WindowHandle) -> (int, int) {
    return (800, 600);
}

// 事件处理
fn pollEvent(handle: WindowHandle, event: &Event) -> bool {
    // 非阻塞事件轮询
    // 如果有事件返回 true，填充 event 结构
    // 如果没有事件返回 false
    
    // 实现说明:
    // 1. 调用 PeekMessage 检查是否有消息
    // 2. 如果有，调用 TranslateMessage 和 DispatchMessage
    // 3. 根据消息填充 Event 结构
    // 4. 返回是否有消息
    
    event.msg = MessageType.None;
    return false;
}

fn waitEvent(handle: WindowHandle, event: &Event) {
    // 阻塞等待事件
    // 实现同 pollEvent 但调用 GetMessage
}

// 键盘处理
fn isKeyDown(key: VirtualKey) -> bool {
    // 调用 GetAsyncKeyState 检查按键状态
    return false;
}

// 帧缓冲
fn getFrameBuffer(handle: WindowHandle) -> rawptr {
    // 返回直接写入的像素缓冲地址
    return nil;
}

fn getFrameBufferPitch(handle: WindowHandle) -> int {
    // 返回每行字节数 (width * 4 for 32-bit)
    return 800 * 4;
}

