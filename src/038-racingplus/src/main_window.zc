        t3.innerRects[1] = Rect.{ x: 440, y: 160, width: 200, height: 380 };
        
        t3.checkpoints[0] = Checkpoint.{ x: 90, y: 300, width: 20, height: 80, id: 0 };
        t3.checkpoints[1] = Checkpoint.{ x: 300, y: 90, width: 80, height: 20, id: 1 };
        t3.checkpoints[2] = Checkpoint.{ x: 500, y: 590, width: 80, height: 20, id: 2 };
        t3.checkpoints[3] = Checkpoint.{ x: 790, y: 300, width: 20, height: 80, id: 3 };
        t3.checkpointCount = 4;
        
        t3.obstacles[0] = Obstacle.{ x: 280, y: 200, width: 40, height: 40, active: true };
        t3.obstacles[1] = Obstacle.{ x: 280, y: 450, width: 40, height: 40, active: true };
        t3.obstacles[2] = Obstacle.{ x: 560, y: 200, width: 40, height: 40, active: true };
        t3.obstacles[3] = Obstacle.{ x: 560, y: 450, width: 40, height: 40, active: true };
        t3.obstacles[4] = Obstacle.{ x: 400, y: 320, width: 50, height: 50, active: true };
        t3.obstacleCount = 5;
        
        // ===== 赛道5: 高速赛道 (极限) =====
        var t4 = &self.tracks[4];
        t4.name = "Speedway Extreme";
        t4.type = TrackType.Speedway;
        t4.difficulty = Difficulty.Extreme;
        t4.lapCount = 5;
        t4.timeLimit = 180000;  // 3分钟
        t4.startX = WINDOW_WIDTH / 2.0;
        t4.startY = WINDOW_HEIGHT - 100.0;
