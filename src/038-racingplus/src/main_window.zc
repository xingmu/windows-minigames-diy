        // L形技术赛道
        t1.outerRects[0] = Rect.{ x: 80, y: 80, width: 300, height: 540 };
        t1.outerRects[1] = Rect.{ x: 80, y: 80, width: 740, height: 200 };
        t1.outerRects[2] = Rect.{ x: 620, y: 80, width: 200, height: 540 };
        t1.innerRects[0] = Rect.{ x: 160, y: 160, width: 140, height: 380 };
        t1.innerRects[1] = Rect.{ x: 160, y: 160, width: 520, height: 100 };
