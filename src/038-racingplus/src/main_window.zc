        // 高速长直道
        t4.outerRects[0] = Rect.{ x: 50, y: 50, width: 800, height: 600 };
        t4.innerRects[0] = Rect.{ x: 130, y: 130, width: 640, height: 440 };
        
        t4.checkpoints[0] = Checkpoint.{ x: 400, y: 60, width: 100, height: 20, id: 0 };
        t4.checkpoints[1] = Checkpoint.{ x: 820, y: 300, width: 20, height: 100, id: 1 };
        t4.checkpoints[2] = Checkpoint.{ x: 400, y: 620, width: 100, height: 20, id: 2 };
