        t1.checkpoints[0] = Checkpoint.{ x: 200, y: 90, width: 80, height: 20, id: 0 };
        t1.checkpoints[1] = Checkpoint.{ x: 750, y: 150, width: 20, height: 80, id: 1 };
        t1.checkpoints[2] = Checkpoint.{ x: 650, y: 580, width: 80, height: 20, id: 2 };
        t1.checkpoints[3] = Checkpoint.{ x: 130, y: 450, width: 20, height: 80, id: 3 };
        t1.checkpointCount = 4;
        
        // 障碍物
        t1.obstacles[0] = Obstacle.{ x: 300, y: 350, width: 40, height: 40, active: true };
        t1.obstacles[1] = Obstacle.{ x: 500, y: 300, width: 40, height: 40, active: true };
        t1.obstacleCount = 2;
        
        // ===== 赛道3: 8字赛道 (困难) =====
        var t2 = &self.tracks[2];
        t2.name = "Figure-8 Fury";
        t2.type = TrackType.Figure8;
        t2.difficulty = Difficulty.Hard;
        t2.lapCount = 3;
        t2.timeLimit = 120000;  // 2分钟
        t2.startX = WINDOW_WIDTH / 2.0;
        t2.startY = WINDOW_HEIGHT - 120.0;
        t2.startAngle = -3.14159 / 2.0;
        
        // 8字外框
        t2.outerRects[0] = Rect.{ x: 100, y: 50, width: 700, height: 280 };
        t2.outerRects[1] = Rect.{ x: 100, y: 370, width: 700, height: 280 };
        t2.innerRects[0] = Rect.{ x: 180, y: 130, width: 540, height: 100 };
        t2.innerRects[1] = Rect.{ x: 180, y: 450, width: 540, height: 100 };
        
        t2.checkpoints[0] = Checkpoint.{ x: 400, y: 60, width: 80, height: 20, id: 0 };
        t2.checkpoints[1] = Checkpoint.{ x: 780, y: 170, width: 20, height: 60, id: 1 };
        t2.checkpoints[2] = Checkpoint.{ x: 400, y: 380, width: 80, height: 20, id: 2 };
        t2.checkpoints[3] = Checkpoint.{ x: 100, y: 170, width: 20, height: 60, id: 3 };
        t2.checkpoints[4] = Checkpoint.{ x: 400, y: 620, width: 80, height: 20, id: 4 };
        t2.checkpoints[5] = Checkpoint.{ x: 780, y: 470, width: 20, height: 60, id: 5 };
        t2.checkpoints[6] = Checkpoint.{ x: 400, y: 270, width: 80, height: 20, id: 6 };
        t2.checkpoints[7] = Checkpoint.{ x: 100, y: 470, width: 20, height: 60, id: 7 };
        t2.checkpointCount = 8;
        
        t2.obstacles[0] = Obstacle.{ x: 250, y: 150, width: 35, height: 35, active: true };
        t2.obstacles[1] = Obstacle.{ x: 600, y: 150, width: 35, height: 35, active: true };
        t2.obstacles[2] = Obstacle.{ x: 250, y: 500, width: 35, height: 35, active: true };
        t2.obstacles[3] = Obstacle.{ x: 600, y: 500, width: 35, height: 35, active: true };
        t2.obstacleCount = 4;
        
        // ===== 赛道4: 卡丁车道 (困难) =====
        var t3 = &self.tracks[3];
        t3.name = "Karting Chaos";
        t3.type = TrackType.Karting;
        t3.difficulty = Difficulty.Hard;
        t3.lapCount = 4;
