// 038-racingplus - 俯视角赛车游戏增强版
// Zen-C + 003-framework
// 更多赛道，更高难度
// 操作: ↑ 加速, ← → 转向, SPACE 刹车

import "platform_api.zc";
import "game.zc";

// ============================================================================
// 游戏配置
// ============================================================================
const WINDOW_WIDTH = 900;
const WINDOW_HEIGHT = 700;
const FPS = 60;

// 赛车参数
const CAR_WIDTH = 18;
const CAR_HEIGHT = 28;
const MAX_SPEED = 10;
const ACCELERATION = 4;
const BRAKE_POWER = 6;
const FRICTION = 0.97;
const TURN_SPEED = 5;
const OFF_ROAD_FRICTION = 0.88;

// 难度等级
pub type Difficulty = enum {
    Easy,      // 简单 - 宽赛道，无障碍
    Normal,    // 普通 - 中等赛道，少量障碍
    Hard,      // 困难 - 窄赛道，多障碍，时间限制
    Extreme,   // 极限 - 最窄赛道，很多障碍
};

// 赛道类型
pub type TrackType = enum {
    Oval,           // 椭圆赛道
    Figure8,        // 8字赛道
    Technical,      // 技术赛道 (多弯)
    Speedway,       // 高速赛道 (长直道)
    Karting,        // 卡丁车道 (S弯)
};

// ============================================================================
// 赛车
// ============================================================================
struct Car {
    x: float;
    y: float;
    angle: float;
    speed: float;
    steering: float;
    accelerating: bool;
    braking: bool;
    checkpointTimes: [u32, 8];
    currentCheckpoint: int;
    finishTime: u32;
}

// ============================================================================
// 障碍物
// ============================================================================
struct Obstacle {
    x: int;
    y: int;
    width: int;
    height: int;
    active: bool;
};

// ============================================================================
// 检查点
// ============================================================================
struct Checkpoint {
    x: int;
    y: int;
    width: int;
    height: int;
    id: int;
};

// ============================================================================
// 赛道定义
// ============================================================================
struct TrackDef {
    name: str;
    type: TrackType;
    difficulty: Difficulty;
    outerRects: [Rect, 4];
    innerRects: [Rect, 4];
    checkpoints: [Checkpoint, 8];
    obstacles: [Obstacle, 12];
    obstacleCount: int;
    lapCount: int;
    timeLimit: u32;  // 毫秒，0表示无限制
    startX: float;
    startY: float;
    startAngle: float;
}

// ============================================================================
// 赛车游戏主类
// ============================================================================
class RacingGamePlus extends Game {
    // 赛车
    car: Car;
    
    // 赛道
    currentTrack: int;
    tracks: [TrackDef, 5];
    trackOuter: Rect;
    trackInner: Rect;
    checkpoints: [Checkpoint, 8];
    checkpointCount: int;
    obstacles: [Obstacle, 12];
    obstacleCount: int;
    
    // 圈数
    lap: int;
    totalLaps: int;
    lastCheckpoint: int;
    bestLapTime: u32;
    currentLapStart: u32;
    
    // 按键状态
    keyUp: bool;
    keyLeft: bool;
    keyRight: bool;
    keySpace: bool;
    
    // 速度表
    maxSpeedSeen: float;
    
    // 计时
    startTime: u32;
    elapsedTime: u32;
    raceTimeLimit: u32;
    timeUp: bool;
    
    // 难度
    difficulty: Difficulty;
    
    // 粒子效果
    tireMarks: [TireMark, 100];
    tireMarkCount: int;
    dustParticles: [DustParticle, 50];
    dustCount: int;
    
    // 速度线
    speedLines: [SpeedLine, 20];
    speedLineCount: int;
    
    // 菜单状态
    inMenu: bool;
    selectedTrack: int;
    selectedDifficulty: int;
    
    // 完成状态
    raceFinished: bool;
    finishPosition: int;
    
    // 弯道减速辅助
    isSharpTurn: bool;
    nearObstacle: bool;
}

struct TireMark {
    x: int;
    y: int;
    age: int;
    active: bool;
}

struct DustParticle {
    x: float;
    y: float;
    vx: float;
    vy: float;
    life: int;
    active: bool;
}

struct SpeedLine {
    x1: int;
    y1: int;
    x2: int;
    y2: int;
    alpha: int;
    active: bool;
}

impl RacingGamePlus {
    fn defineTracks() {
        // ===== 赛道1: 椭圆赛道 (简单) =====
        var t0 = &self.tracks[0];
        t0.name = "Sunset Oval";
        t0.type = TrackType.Oval;
        t0.difficulty = Difficulty.Easy;
        t0.lapCount = 3;
        t0.timeLimit = 0;
        t0.startX = WINDOW_WIDTH / 2.0;
        t0.startY = WINDOW_HEIGHT - 120.0;
        t0.startAngle = -3.14159 / 2.0;
        
        t0.outerRects[0] = Rect.{ x: 100, y: 80, width: 700, height: 540 };
        t0.innerRects[0] = Rect.{ x: 180, y: 160, width: 540, height: 380 };
        
        // 检查点 (8字形排列)
        t0.checkpoints[0] = Checkpoint.{ x: 400, y: 90, width: 100, height: 20, id: 0 };
        t0.checkpoints[1] = Checkpoint.{ x: 780, y: 300, width: 20, height: 100, id: 1 };
        t0.checkpoints[2] = Checkpoint.{ x: 400, y: 590, width: 100, height: 20, id: 2 };
        t0.checkpoints[3] = Checkpoint.{ x: 100, y: 300, width: 20, height: 100, id: 3 };
