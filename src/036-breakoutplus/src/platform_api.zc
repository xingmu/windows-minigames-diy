def SRCCOPY: u32 = 0x00CC0020;
def BLACKNESS: u32 = 0x00000042;
def WHITENESS: u32 = 0x00FF0062;
def PATCOPY: u32 = 0x00F00021;
def TRANSPARENT: i32 = 1;
def OPAQUE: i32 = 2;

def IDC_ARROW: i16 = 32512;
def IDI_APPLICATION: i16 = 32513;

def WS_OVERLAPPEDWINDOW: u32 = 0x00CF0000;
def WS_VISIBLE: u32 = 0x10000000;
def WS_CHILD: u32 = 0x40000000;
def CW_USEDEFAULT: i32 = (i32)(0x80000000);

def WM_CLOSE: u32 = 0x0010;
def WM_DESTROY: u32 = 0x0002;
def WM_SIZE: u32 = 0x0005;
def WM_PAINT: u32 = 0x000F;
def WM_TIMER: u32 = 0x0113;
def WM_KEYDOWN: u32 = 0x0100;
def WM_KEYUP: u32 = 0x0101;
def WM_LBUTTONDOWN: u32 = 0x0201;
def WM_LBUTTONUP: u32 = 0x0202;
def WM_MOUSEMOVE: u32 = 0x0200;

def VK_LEFT: i32 = 0x25;
def VK_RIGHT: i32 = 0x27;
def VK_UP: i32 = 0x26;
def VK_DOWN: i32 = 0x28;
def VK_SPACE: i32 = 0x20;
def VK_ESCAPE: i32 = 0x1B;
def VK_RETURN: i32 = 0x0D;

struct WNDCLASSEXA {
    cbSize: u32,
    style: u32,
    lpfnWndProc: void*,
    cbClsExtra: i32,
    cbWndExtra: i32,
    hInstance: void*,
    hIcon: void*,
    hCursor: void*,
    hbrBackground: void*,
    lpszMenuName: i8*,
    lpszClassName: i8*,
    hIconSm: void*,
}

struct RECT {
    left: i32,
    top: i32,
    right: i32,
    bottom: i32,
}

struct PAINTSTRUCT {
    hDC: GraphicsContext,
    fErase: bool,
    rcPaint: RECT,
    fRestore: bool,
    fIncUpdate: bool,
    rgbReserved: [i8; 32],
}

struct MSG {
    hwnd: WindowHandle,
    message: u32,
    wParam: u64,
    lParam: i64,
    time: u32,
    pt: [i32; 2],
}

struct POINT {
    x: i32,
    y: i32,
}

static mut msg: MSG;
static mut ps: PAINTSTRUCT;
static mut wc: WNDCLASSEXA;
static mut hwnd: WindowHandle;
static mut custom_window_class: [i8; 256];

static mut frame_buffer: [void*] = [];
static mut fb_width: i32 = 0;
static mut fb_height: i32 = 0;
static mut fb_memDC: GraphicsContext = null;
static mut fb_bitmap: void* = null;
static mut fb_hdc: GraphicsContext = null;
static mut fb_valid: bool = false;

static mut key_handler_fn: *fn(KeyCode) -> bool = null;
static mut timer_handler_fn: *fn() -> bool = null;
static mut paint_handler_fn: *fn(i32, i32) -> void = null;
static mut mouse_handler_fn: *fn(i32, i32) -> void = null;
static mut destroy_handler_fn: *fn() -> void = null;
static mut timer_id: u32 = 0;

fn windowProc(hWnd: WindowHandle, Msg: u32, wParam: u64, lParam: i64) -> i64 {
    match Msg {
        WM_PAINT => {
            let rect: RECT;
            GetClientRect(hWnd, &(void)(rect)*);
            BeginPaint(hWnd, &(void)(ps)*);
            if paint_handler_fn != null {
                paint_handler_fn(rect.right - rect.left, rect.bottom - rect.top);
            }
            BitBlt(ps.hDC, 0, 0, fb_width, fb_height, fb_hdc, 0, 0, SRCCOPY);
            EndPaint(hWnd, &(void)(ps)*);
            return 0;
        },
        WM_TIMER => {
            if timer_handler_fn != null {
                if timer_handler_fn() {
                    InvalidateRect(hWnd, null, false);
                }
            }
            return 0;
        },
        WM_KEYDOWN => {
            let k = mapVirtualKey((i32)wParam);
            if k != KeyCode.KeyUnknown && key_handler_fn != null {
                if key_handler_fn(k) {
                    InvalidateRect(hWnd, null, false);
                }
            }
            return 0;
        },
        WM_KEYUP => {
            return 0;
        },
        WM_LBUTTONDOWN => {
            let x = (lParam & 0xFFFF) as i32;
            let y = ((lParam >> 16) & 0xFFFF) as i32;
            if mouse_handler_fn != null {
                mouse_handler_fn(x, y);
                InvalidateRect(hWnd, null, false);
            }
            return 0;
        },
        WM_MOUSEMOVE => {
            let x = (lParam & 0xFFFF) as i32;
            let y = ((lParam >> 16) & 0xFFFF) as i32;
            if mouse_handler_fn != null {
                mouse_handler_fn(x, y);
            }
            return 0;
        },
        WM_SIZE => {
            let w = (lParam & 0xFFFF) as i32;
            let h = ((lParam >> 16) & 0xFFFF) as i32;
            fb_init(hWnd, w, h);
            return 0;
        },
        WM_CLOSE => {
            PostQuitMessage(0);
            return 0;
        },
        WM_DESTROY => {
            if destroy_handler_fn != null {
                destroy_handler_fn();
            }
            return 0;
        },
    }
    DefWindowProcA(hWnd, Msg, wParam, lParam)
}

fn mapVirtualKey(code: i32) -> KeyCode {
    match code {
        VK_LEFT => KeyCode.KeyLeft,
        VK_RIGHT => KeyCode.KeyRight,
        VK_UP => KeyCode.KeyUp,
        VK_DOWN => KeyCode.KeyDown,
        VK_SPACE => KeyCode.KeySpace,
        VK_ESCAPE => KeyCode.KeyEscape,
        0x52 => KeyCode.KeyR,
        0x57 => KeyCode.KeyW,
        0x41 => KeyCode.KeyA,
        0x53 => KeyCode.KeyS,
        0x44 => KeyCode.KeyD,
        0x50 => KeyCode.KeyP,
        0x31 => KeyCode.Key1,
        0x32 => KeyCode.Key2,
        0x33 => KeyCode.Key3,
        VK_RETURN => KeyCode.KeySpace,
        _ => KeyCode.KeyUnknown,
    }
}

fn fb_init(hWnd: WindowHandle, w: i32, h: i32) {
    fb_width = w;
    fb_height = h;

    if fb_hdc != null {
        return;
    }

    let screenDC = CreateCompatibleDC(null);
    fb_bitmap = CreateCompatibleBitmap(screenDC, w, h);
    fb_hdc = CreateCompatibleDC(screen32);
    SelectBitmap(fb_hdc, fb_bitmap);
    PatBlt(fb_hdc, 0, 0, w, h, BLACKNESS);
    DeleteObject((void)(screenDC)*);
    fb_valid = true;
}

fn fb_clear(color: u32) {
    if !fb_valid {
        return;
    }
    let brush = CreateSolidBrush(color);
    let rect: RECT;
    rect.left = 0;
    rect.top = 0;
    rect.right = fb_width;
    rect.bottom = fb_height;
    FillRect(fb_hdc, &(void)(rect)*, brush);
    DeleteObject(brush);
}

fn fb_draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32) {
    if !fb_valid {
        return;
    }
    let brush = CreateSolidBrush(color);
    let rect: RECT;
    rect.left = x;
    rect.top = y;
    rect.right = x + w;
    rect.bottom = y + h;
    FillRect(fb_hdc, &(void)(rect)*, brush);
    DeleteObject(brush);
}

fn fb_draw_circle(cx: i32, cy: i32, r: i32, color: u32) {
    if !fb_valid {
        return;
    }
    let brush = CreateSolidBrush(color);
    let rect: RECT;
    rect.left = cx - r;
    rect.top = cy - r;
    rect.right = cx + r;
    rect.bottom = cy + r;
    FillRect(fb_hdc, &(void)(rect)*, brush);
    DeleteObject(brush);
}

fn fb_draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32) {
    if !fb_valid {
        return;
    }
    let pen = CreatePen(0, 1, color);
    let oldPen = SelectPen(fb_hdc, pen);
    MoveToEx(fb_hdc, x1, y1, null);
    LineTo(fb_hdc, x2, y2);
    SelectPen(fb_hdc, oldPen);
    DeleteObject((void)(pen)*);
}

fn fb_draw_text_size(x: i32, y: i32, text: str, color: u32, size: i32) {
    if !fb_valid {
        return;
    }
    SetBkMode(fb_hdc, TRANSPARENT);
    SetTextColor(fb_hdc, color);
    let cstr = text.toCString();
    TextOutA(fb_hdc, x, y, cstr.asPtr(), text.(i32)length);
}

fn fb_present() {
    // Double buffering handled in WM_PAINT
}

fn fb_shutdown() {
    fb_valid = false;
    if fb_bitmap != null {
        DeleteObject(fb_bitmap);
        fb_bitmap = null;
    }
    if fb_hdc != null {
        DeleteDC(fb_hdc);
        fb_hdc = null;
    }
}

fn create_window(title: str, width: i32, height: i32) -> WindowHandle {
    let hInstance = GetModuleHandleA(null);

    let className = "ZenGameClass";

    wc.cbSize = 48;
    wc.style = 0;
    wc.lpfnWndProc = (void)(windowProc)*;
    wc.cbClsExtra = 0;
    wc.cbWndExtra = 0;
    wc.hInstance = hInstance;
    wc.hIcon = LoadIconA(null, cast((i8)(IDI_APPLICATION)*));
    wc.hCursor = LoadCursorA(null, cast((i8)(IDC_ARROW)*));
    wc.hbrBackground = null;
    wc.lpszMenuName = null;
    wc.lpszClassName = className.asPtr();
    wc.hIconSm = null;

    RegisterClassExA(&(i8)(wc)*);

    hwnd = CreateWindowExA(
        0,
        className.asPtr(),
        title.asPtr(),
        WS_OVERLAPPEDWINDOW,
        CW_USEDEFAULT, CW_USEDEFAULT,
        width + 16, height + 39,
        null, null, hInstance, null
    );

    if hwnd != null {
        show_window(hwnd);
    }

    hwnd
}

fn show_window(hWnd: WindowHandle) {
    ShowWindow(hWnd, 1);
    UpdateWindow(hWnd);
}

fn get_window_client_size(hWnd: WindowHandle, w: i32*, h: i32*) {
    let rect: RECT;
    GetClientRect(hWnd, &(void)(rect)*);
    w = rect.right - rect.left;
    h = rect.bottom - rect.top;
}

fn set_client_size(w: i32, h: i32) {
    fb_init(hwnd, w, h);
}

fn redraw_window(hWnd: WindowHandle) {
    InvalidateRect(hWnd, null, false);
}

fn run_event_loop(hWnd: WindowHandle) {
    while true {
        if !GetMessageA(&(void)(msg)*, hWnd, 0, 0) {
            break;
        }
        TranslateMessage(&(void)(msg)*);
        DispatchMessageA(&(void)(msg)*);
    }
}

fn set_game_timer(hWnd: WindowHandle, ms: u32) {
    timer_id = SetTimer(hWnd, 1, ms, null);
}

fn stop_timer(hWnd: WindowHandle) {
    if timer_id != 0 {
        KillTimer(hWnd, timer_id);
        timer_id = 0;
    }
}

fn getTickCount() -> u32 {
    GetTickCount()
}

fn set_key_handler(fnptr: *fn(KeyCode) -> bool) {
    key_handler_fn = fnptr;
}

fn set_timer_handler(fnptr: *fn() -> bool) {
    timer_handler_fn = fnptr;
}

fn set_paint_handler(fnptr: *fn(i32, i32) -> void) {
    paint_handler_fn = fnptr;
}

fn set_mouse_handler(fnptr: *fn(i32, i32) -> void) {
    mouse_handler_fn = fnptr;
}

fn set_destroy_handler(fnptr: *fn() -> void) {
    destroy_handler_fn = fnptr;
}

fn closeWindow(hWnd: WindowHandle) {
    if timer_id != 0 {
        KillTimer(hWnd, timer_id);
        timer_id = 0;
    }
    PostMessageA(hWnd, WM_CLOSE, 0, 0);
}

