// mahjong_logic.zc - 麻将游戏核心逻辑
// 麻将牌定义、AI、吃碰杠胡判定

import "io.zc";

// ==================== 麻将牌定义 ====================

// 牌的类型
enum TileType {
    // 万子 1-9
    Wan1, Wan2, Wan3, Wan4, Wan5, Wan6, Wan7, Wan8, Wan9,
    // 筒子 1-9
    Tong1, Tong2, Tong3, Tong4, Tong5, Tong6, Tong7, Tong8, Tong9,
    // 索子 1-9
    Suo1, Suo2, Suo3, Suo4, Suo5, Suo6, Suo7, Suo8, Suo9,
    // 风牌
    Dong, Nan, Xi, Bei,
    // 三元牌
    Zhong, Fa, Bai,
};

// 牌的花色
enum TileSuit {
    Wan,    // 万子
    Tong,   // 筒子
    Suo,    // 索子
    Feng,   // 风牌
    Yuan,   // 三元牌
};

// 获取牌的花色
pub fn getTileSuit(tile: TileType) -> TileSuit {
    match tile {
        TileType.Wan1...TileType::Wan9 => return TileSuit.Wan,
        TileType.Tong1...TileType::Tong9 => return TileSuit.Tong,
        TileType.Suo1...TileType::Suo9 => return TileSuit.Suo,
        TileType.Dong...TileType::Bei => return TileSuit.Feng,
        TileType.Zhong, TileType.Fa, TileType::Bai => return TileSuit.Yuan,
    }
}

// 获取牌的值（1-9对于数牌，0对于字牌）
pub fn getTileValue(tile: TileType) -> int {
    match tile {
        TileType.Wan1...TileType::Wan9 => return ((int)tile - TileType(int)Wan1) + 1,
        TileType.Tong1...TileType::Tong9 => return ((int)tile - TileType(int)Tong1) + 1,
        TileType.Suo1...TileType::Suo9 => return ((int)tile - TileType(int)Suo1) + 1,
        _ => return 0,
    }
}

