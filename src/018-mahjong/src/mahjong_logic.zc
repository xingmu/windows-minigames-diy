// 牌的颜色（用于UI显示）
pub fn getTileColor(tile: TileType) -> (u8, u8, u8) {
    let suit = getTileSuit(tile);
    match suit {
        TileSuit::Wan => return (200, 100, 100),    // 红色系
        TileSuit::Tong => return (100, 150, 220),   // 蓝色系
        TileSuit::Suo => return (100, 180, 100),    // 绿色系
        TileSuit::Feng => return (180, 180, 180),   // 灰色
        TileSuit::Yuan => return (220, 200, 100),   // 金色
    }
}

// ==================== 操作类型 ====================

enum OperationType {
    None,   // 无操作
    Chi,    // 吃
    Peng,   // 碰
    Gang,   // 杠
    Hu,     // 胡
};

// 碰牌信息
pub struct PengInfo {
    tile: TileType;       // 碰的牌
    fromPlayer: int;       // 从哪个玩家碰的 (0=下家, 1=对家, 2=上家)
}

// 杠牌信息
pub struct GangInfo {
    tile: TileType;       // 杠的牌
    fromPlayer: int;      // 从哪个玩家杠的
    gangType: int;        // 0=明杠(碰后杠), 1=暗杠, 2=加杠
}

// 吃牌信息
pub struct ChiInfo {
    tiles: [TileType; 2]; // 吃的另外两张牌(配合打出的牌组成顺子)
    fromPlayer: int;      // 从哪个玩家吃 (0=下家, 1=对家, 2=上家)
}

// 可进行的操作
pub struct PlayerOperation {
    canChi: bool;
    chiInfo: ChiInfo;
    canPeng: bool;
    pengInfo: PengInfo;
    canGang: bool;
    gangInfo: GangInfo;
    canHu: bool;
}

// ==================== 玩家数据 ====================

// 手牌（已排序）
def MAX_HAND_TILES = 16;

// 玩家的牌组（吃、碰、杠的牌）
pub struct Melds {
    chi: [TileType; 3];       // 吃牌（3张）
    peng: [TileType; 3];       // 碰牌（3张）
    gang: [TileType; 4];       // 杠牌（4张）
    hasChi: bool;
    hasPeng: bool;
    hasGang: bool;
}

pub impl Melds {
    pub fn new() -> Melds {
        return Melds {
            chi: [TileType.Wan1, TileType.Wan1, TileType.Wan1],
            peng: [TileType.Wan1, TileType.Wan1, TileType.Wan1],
            gang: [TileType.Wan1, TileType.Wan1, TileType.Wan1, TileType.Wan1],
            hasChi: false,
            hasPeng: false,
            hasGang: false,
        };
    }
}

// ==================== 牌堆管理 ====================

def WALL_SIZE = 144;  // 正式麻将144张

// 牌墙
pub struct TileWall {
    tiles: [TileType; WALL_SIZE];
    top: int;           // 牌墙顶部索引
    dice: [int; 2];     // 骰子点数
}

pub impl TileWall {
    pub fn new() -> TileWall {
        return TileWall {
            tiles: [TileType.Wan1; WALL_SIZE],
            top: WALL_SIZE,
            dice: [0, 0],
        };
    }
    
    // 初始化牌墙（洗牌）
    pub fn shuffle(&self) {
        // 初始化所有牌
        let index = 0;
        // 每种牌4张
        for t in TileType.Wan1...TileType.Wan9 {
            for i in 0..4 {
                self.tiles[index] = t;
                index = index + 1;
            }
        }
        for t in TileType.Tong1...TileType.Tong9 {
            for i in 0..4 {
                self.tiles[index] = t;
                index = index + 1;
            }
        }
        for t in TileType.Suo1...TileType.Suo9 {
            for i in 0..4 {
                self.tiles[index] = t;
                index = index + 1;
            }
        }
        for t in TileType.Dong...TileType.Bei {
            for i in 0..4 {
                self.tiles[index] = t;
                index = index + 1;
            }
        }
        for t in TileType.Zhong...TileType.Bai {
            for i in 0..4 {
                self.tiles[index] = t;
                index = index + 1;
            }
        }
        
        // 洗牌（Fisher-Yates算法）
        setRandomSeed(getTickCount());
        for i in (WALL_SIZE - 1)..0 {
            let j = randInt(0, i);
            let temp = self.tiles[i];
            self.tiles[i] = self.tiles[j];
            self.tiles[j] = temp;
        }
        
        self.top = WALL_SIZE - 1;
    }
    
    // 掷骰子
    pub fn rollDice(&self) {
        self.dice[0] = randInt(1, 6);
        self.dice[1] = randInt(1, 6);
    }
    
    // 摸牌
    pub fn draw(&self) -> TileType {
        if self.top < 0 {
            return TileType.Wan1;  // 无牌可摸
        }
        let tile = self.tiles[self.top];
        self.top = self.top - 1;
        return tile;
    }
    
    // 获取剩余牌数
    pub fn remaining(&self) -> int {
        return self.top + 1;
    }
}

// ==================== 胡牌判定 ====================

def MAX_HAND_SIZE = 16;

// 牌组计数
struct TileCount {
    counts: [int; 34];  // 34种牌的数量
}

fn newTileCount() -> TileCount {
    return TileCount { counts: [0; 34] };
}

fn tileToIndex(t: TileType) -> int {
    return t as int;
}

fn indexToTile(idx: int) -> TileType {
    return idx as TileType;
}

// 统计手牌
fn countTiles(hand: &[TileType; MAX_HAND_SIZE], handSize: int) -> TileCount {
    let count = newTileCount();
    for i in 0..handSize {
        let idx = tileToIndex(hand[i]);
        count.counts[idx] = count.counts[idx] + 1;
    }
    return count;
}

// 检查胡牌（标准麻将规则）
// 返回值: true = 可以胡牌
pub fn canHu(hand: &[TileType; MAX_HAND_SIZE], handSize: int) -> bool {
    // 胡牌需要: 4个面子 + 1个将牌
    // 手牌数必须是3n+2
    
    if (handSize - 2) % 3 != 0 {
        return false;
    }
    
    let count = countTiles(hand, handSize);
    
    // 首先尝试找到一个对子作为将牌
    for i in 0..34 {
        if count.counts[i] >= 2 {
            // 移除这个对子
            count.counts[i] = count.counts[i] - 2;
            
            // 检查剩余的牌能否组成面子
            if canFormMeld(count.counts) {
                count.counts[i] = count.counts[i] + 2;
                return true;
            }
            
            count.counts[i] = count.counts[i] + 2;
        }
    }
    
    return false;
}

// 检查能否组成所有面子（递归版本）
fn canFormMeld(counts: &[int; 34]) -> bool {
    // 找到第一个有牌的索引
    let first = -1;
    for i in 0..34 {
        if counts[i] > 0 {
            first = i;
            break;
        }
    }
    
    if first == -1 {
        return true;  // 所有牌都处理完了
    }
    
    let count = counts[first];
    
    // 刻子（3张相同的牌）
    if count >= 3 {
        let newCounts = counts;
        newCounts[first] = newCounts[first] - 3;
        return canFormMeld(newCounts);
    }
    
    // 顺子（对于数牌，1-9同花色连续3张）
    // Wan: 0-8, Tong: 9-17, Suo: 18-26
    if first <= 24 {  // 可以组成顺子的范围
        let suit = first / 9;
        let value = first % 9;
        
        // 检查是否是数牌
        if suit < 3 {
            // 检查能否组成顺子
            let next1 = suit * 9 + value + 1;
            let next2 = suit * 9 + value + 2;
            
            if value <= 6 && counts[next1] > 0 && counts[next2] > 0 {
                let newCounts = counts;
                newCounts[first] = newCounts[first] - 1;
                newCounts[next1] = newCounts[next1] - 1;
                newCounts[next2] = newCounts[next2] - 1;
                return canFormMeld(newCounts);
            }
        }
    }
    
    return false;
}

// ==================== 吃牌判定 ====================

// 检查能否吃（需要是下家，且牌能组成顺子）
pub fn canChi(hand: &[TileType; MAX_HAND_SIZE], handSize: int, 
              discardedTile: TileType, fromPlayer: int) -> bool {
    // 只有下家可以吃
    if fromPlayer != 0 {
        return false;
    }
    
    let suit = getTileSuit(discardedTile);
    
    // 字牌不能吃
    if suit == TileSuit.Feng || suit == TileSuit.Yuan {
        return false;
    }
    
    let value = getTileValue(discardedTile);
    
    // 统计手牌
    let count = countTiles(hand, handSize);
    let idx = tileToIndex(discardedTile);
    
    // 检查是否能组成顺子
    // 对于吃的牌，有3种情况：
    // 1. 吃的牌是顺子的中间那张 (如 2,3,4 中的3)
    // 2. 吃的牌是顺子的最小那张 (如 2,3,4 中的2)
    // 3. 吃的牌是顺子的最大那张 (如 2,3,4 中的4)
    
    // 情况1: [X-1, X, X+1] - 吃的牌在中间
    if value >= 2 && value <= 8 {
        let suitIdx = (int)suit * 9;
        let idx1 = suitIdx + value - 2;  // X-1
        let idx2 = suitIdx + value - 1;  // X (这张是摸的)
        let idx3 = suitIdx + value;      // X+1
        
        if count.counts[idx1] >= 1 && count.counts[idx3] >= 1 {
            return true;
        }
    }
    
    // 情况2: 吃的牌是最小的那张，如吃2，需要1,2,3中的2
    if value >= 2 && value <= 9 {
        let suitIdx = (int)suit * 9;
        let idx1 = suitIdx + value - 2;  // value-1 (需要这张)
        let idx2 = suitIdx + value - 1;  // value (摸的牌)
        let idx3 = suitIdx + value;      // value+1
        
        if value <= 7 && count.counts[idx1] >= 1 && count.counts[idx3] >= 1 {
            return true;
        }
    }
    
    // 情况3: 吃的牌是最大的那张，如吃4，需要2,3,4中的4
    if value >= 1 && value <= 8 {
        let suitIdx = (int)suit * 9;
        let idx1 = suitIdx + value - 1;  // value-1
        let idx2 = suitIdx + value;       // value (摸的牌)
        let idx3 = suitIdx + value + 1;   // value+1 (需要这张)
        
        if value >= 2 && count.counts[idx1] >= 1 && count.counts[idx3] >= 1 {
            return true;
        }
    }
    
    return false;
}

// 获取吃牌的具体组合
pub fn getChiCombinations(hand: &[TileType; MAX_HAND_SIZE], handSize: int,
                          discardedTile: TileType) -> [[TileType; 2]; 3] {
    let result: [[TileType; 2]; 3] = [[TileType.Wan1, TileType.Wan1], 
                                       [TileType.Wan1, TileType.Wan1],
                                       [TileType.Wan1, TileType.Wan1]];
    let count = 0;
    
    let suit = getTileSuit(discardedTile);
    let value = getTileValue(discardedTile);
    let suitIdx = (int)suit * 9;
    
    // 情况1: [X-1, X, X+1] - X在中间
    if value >= 2 && value <= 8 {
        let idx1 = suitIdx + value - 2;
        let idx3 = suitIdx + value;
        
        if countTiles(hand, handSize).counts[idx1] >= 1 && 
           countTiles(hand, handSize).counts[idx3] >= 1 {
            result[count] = [indexToTile(idx1), indexToTile(idx3)];
            count = count + 1;
        }
    }
    
    // 情况2: 吃的牌是最小的
    if value >= 2 && value <= 7 {
        let idx1 = suitIdx + value - 2;
        let idx3 = suitIdx + value;
        
        if countTiles(hand, handSize).counts[idx1] >= 1 && 
           countTiles(hand, handSize).counts[idx3] >= 1 {
            result[count] = [indexToTile(idx1), indexToTile(idx3)];
            count = count + 1;
        }
    }
    
    // 情况3: 吃的牌是最大的
    if value >= 3 && value <= 8 {
        let idx1 = suitIdx + value - 2;
        let idx3 = suitIdx + value;
        
        if countTiles(hand, handSize).counts[idx1] >= 1 && 
           countTiles(hand, handSize).counts[idx3] >= 1 {
            result[count] = [indexToTile(idx1), indexToTile(idx3)];
            count = count + 1;
        }
    }
    
    return result;
}

// ==================== 碰牌判定 ====================

// 检查能否碰
pub fn canPeng(hand: &[TileType; MAX_HAND_SIZE], handSize: int, 
               discardedTile: TileType) -> bool {
    let count = countTiles(hand, handSize);
    let idx = tileToIndex(discardedTile);
    return count.counts[idx] >= 2;
}

// ==================== 杠牌判定 ====================

// 检查能否杠（手牌中有3张相同）
pub fn canGang(hand: &[TileType; MAX_HAND_SIZE], handSize: int,
               discardedTile: TileType) -> bool {
    let count = countTiles(hand, handSize);
    let idx = tileToIndex(discardedTile);
    return count.counts[idx] >= 3;
}

// 检查能否暗杠（手牌中有4张相同）
pub fn canAnGang(hand: &[TileType; MAX_HAND_SIZE], handSize: int) -> [TileType; 4] {
    let result: [TileType; 4] = [TileType.Wan1, TileType.Wan1, TileType.Wan1, TileType.Wan1];
    let count = 0;
    
    let tileCount = countTiles(hand, handSize);
    for i in 0..34 {
        if tileCount.counts[i] >= 4 {
            result[count] = indexToTile(i);
            count = count + 1;
            if count >= 4 {
                break;
            }
        }
    }
    
    // 返回能暗杠的牌数（0-4）
    // 这里用一个技巧：把数量编码进返回值的某些位置
    // 实际上我们只需要知道有哪些牌可以暗杠
    return result;
}

// 获取可杠的牌列表
pub fn getGangTiles(hand: &[TileType; MAX_HAND_SIZE], handSize: int,
                    lastTile: TileType) -> [bool; 34] {
    let result: [bool; 34] = [false; 34];
    
    // 明杠：手牌有3张和摸来的牌相同
    let count = countTiles(hand, handSize);
    let idx = tileToIndex(lastTile);
    if count.counts[idx] >= 3 {
        result[idx] = true;
    }
    
    // 暗杠：手牌有4张相同的牌
    for i in 0..34 {
        if count.counts[i] >= 4 {
            result[i] = true;
        }
    }
    
    return result;
}

// ==================== AI 逻辑 ====================

// AI难度级别
enum AILevel {
    Easy,    // 简单：随机出牌
    Normal, // 普通：避免放炮
    Hard,   // 困难：优化胡牌
};

// AI决策
pub struct AIDecision {
    discardTile: TileType;    // 要打出的牌
    wantGang: bool;           // 是否要杠
    gangTile: TileType;       // 杠哪张牌
    wantHu: bool;             // 是否要胡
}

// 根据AI级别做决策
pub fn aiDecision(hand: &[TileType; MAX_HAND_SIZE], handSize: int,
                  aiLevel: AILevel, gameState: GameState*) -> AIDecision {
    match aiLevel {
        AILevel::Easy => return aiEasyDecision(hand, handSize),
        AILevel::Normal => return aiNormalDecision(hand, handSize),
        AILevel::Hard => return aiHardDecision(hand, handSize, gameState),
    }
}

// 简单AI：随机出牌
fn aiEasyDecision(hand: &[TileType; MAX_HAND_SIZE], handSize: int) -> AIDecision {
    let decision: AIDecision;
    decision.discardTile = hand[randInt(0, handSize - 1)];
    decision.wantGang = false;
    decision.gangTile = TileType.Wan1;
    decision.wantHu = false;
    return decision;
}

// 普通AI：避免放炮
fn aiNormalDecision(hand: &[TileType; MAX_HAND_SIZE], handSize: int) -> AIDecision {
    let decision: AIDecision;
    decision.wantGang = false;
    decision.wantHu = false;
    
    // 统计手牌
    let count = countTiles(hand, handSize);
    
    // 优先打孤张（只在手牌中出现1次的牌）
    let safeTile = hand[0];
    let minCount = 999;
    
    for i in 0..handSize {
        let idx = tileToIndex(hand[i]);
        let c = count.counts[idx];
        
        // 字牌和数牌边缘的张更安全
        let isSafe = true;
        if c >= 2 {
            isSafe = false;  // 有对子的牌不安全
        }
        
        // 检查是否是有效牌的边张
        let suit = getTileSuit(hand[i]);
        let value = getTileValue(hand[i]);
        if suit == TileSuit.Wan || suit == TileSuit.Tong || suit == TileSuit.Suo {
            // 1和9风险较高
            if value == 1 || value == 9 {
                if c == 1 {
                    safeTile = hand[i];
                    minCount = 0;
                }
            }
        }
        
        // 如果是孤张，打出去
        if c == 1 && isSafe && minCount > 0 {
            safeTile = hand[i];
            minCount = 1;
        }
    }
    
    // 如果没有找到孤张，打出现次数最少的
    if minCount == 999 {
        for i in 0..handSize {
            let idx = tileToIndex(hand[i]);
            if count.counts[idx] < minCount {
                minCount = count.counts[idx];
                safeTile = hand[i];
            }
        }
    }
    
    decision.discardTile = safeTile;
    return decision;
}

// 困难AI：优化胡牌机会
fn aiHardDecision(hand: &[TileType; MAX_HAND_SIZE], handSize: int,
                  gameState: GameState*) -> AIDecision {
    let decision: AIDecision;
    decision.wantGang = false;
    decision.wantHu = false;
    
    // 统计手牌
    let count = countTiles(hand, handSize);
    
    // 计算每张牌的"价值"
    let bestTile = hand[0];
    let bestScore = -999;
    
    for i in 0..handSize {
        let idx = tileToIndex(hand[i]);
        let score = 0;
        
        // 基本分数：与其它牌的关联
        let suit = getTileSuit(hand[i]);
        let value = getTileValue(hand[i]);
        
        if suit == TileSuit.Wan || suit == TileSuit.Tong || suit == TileSuit.Suo {
            // 数牌：与相邻牌的关联
            if value >= 2 {
                let idx1 = idx - 1;
                score = score + count.counts[idx1] * 2;
            }
            if value <= 8 {
                let idx1 = idx + 1;
                score = score + count.counts[idx1] * 2;
            }
            if value >= 3 {
                let idx1 = idx - 2;
                score = score + count.counts[idx1];
            }
            if value <= 7 {
                let idx1 = idx + 2;
                score = score + count.counts[idx1];
            }
            
            // 中间张价值更高
            if value >= 4 && value <= 6 {
                score = score + 3;
            }
            
            // 1和9价值较低
            if value == 1 || value == 9 {
                score = score - 2;
            }
        } else {
            // 字牌：只有相同才能组成刻子
            score = score + count.counts[idx] - 1;
        }
        
        // 刻子加分
        if count.counts[idx] >= 3 {
            score = score + 10;
        }
        
        // 对子加分
        if count.counts[idx] == 2 {
            score = score + 5;
        }
        
        // 检查打出后是否影响胡牌
        // （简化处理：不影响太多）
        
        if score > bestScore {
            bestScore = score;
            bestTile = hand[i];
        }
    }
    
    decision.discardTile = bestTile;
    return decision;
}

// 游戏状态（用于AI参考）
struct GameState {
    // 场上已打出的牌
    discardedTiles: [TileType; WALL_SIZE];
    discardedCount: int;
    
    // 各玩家状态
    playerScores: [int; 4];
}

// 排序手牌
pub fn sortHand(hand: &[TileType; MAX_HAND_SIZE], handSize: int) {
    // 简单的冒泡排序
    for i in 0..handSize {
        for j in (i + 1)..handSize {
            let idx1 = tileToIndex(hand[i]);
            let idx2 = tileToIndex(hand[j]);
            if idx1 > idx2 {
                let temp = hand[i];
                hand[i] = hand[j];
                hand[j] = temp;
            }
        }
    }
}

// 从手牌中移除一张牌
pub fn removeFromHand(hand: &[TileType; MAX_HAND_SIZE], handSize: int, 
                      tile: TileType) -> bool {
    for i in 0..handSize {
        if hand[i] == tile {
            // 移除这张牌，后面的牌前移
            for j in i..(handSize - 1) {
                hand[j] = hand[j + 1];
            }
            hand[handSize - 1] = TileType.Wan1;  // 填充无效值
            return true;
        }
    }
    return false;
}

// 检查操作优先级
pub fn getOperationPriority(op: OperationType) -> int {
    match op {
        OperationType::Hu => return 4;    // 胡最高
        OperationType::Gang => return 3; // 杠次之
        OperationType::Peng => return 2; // 碰
        OperationType::Chi => return 1;  // 吃最低
        _ => return 0;
    }
}
